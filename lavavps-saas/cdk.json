{
  "app": "npx ts-node -P infra/tsconfig.json infra/bin/app.ts",
  "watch": {
    "include": ["infra/**"],
    "exclude": ["**/node_modules/**", "infra/cdk.out/**"]
  },
  "context": {
    "@aws-cdk/aws-lambda:recognizeLayerVersion": true,
    "@aws-cdk/aws-cloudformation:useNewS3Upload": true,
    "@aws-cdk/aws-apigateway:usagePlanKeyOrderInsensitiveId": true,
    "@aws-cdk/aws-ec2:launchTemplateDefaultUserData": true,
    "@aws-cdk/aws-secretsmanager:useAttachedSecretResourcePolicyForSecretTargetAttachments": true,
    "@aws-cdk/aws-redshift:columnId": true,
    "@aws-cdk/aws-stepfunctions-tasks:enableEmrServicePolicyV2": true,
    "@aws-cdk/aws-ec2:restrictDefaultSecurityGroup": true,
    "@aws-cdk/aws-elasticloadbalancingv2:albControllerVersion": true,
    "@aws-cdk/aws-rds:clusterActivityStream": true,
    "@aws-cdk/aws-cognito:standardAttributesMutable": true
  }
}
