{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": ".",
    "rootDir": ".",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "moduleResolution": "node"
  },
  "include": [
    "handlers/*/index.ts",
    "layer/src/*.ts"
  ],
  "exclude": [
    "node_modules",
    "handlers/billingHandler/node_modules"
  ]
}
